# Centralized environment file
# Copy to .env.properties and fill in real values. DO NOT commit this file.

# Active profile: 'dev' or 'prod'
SPRING_PROFILES_ACTIVE=prod

# --- Production DB (used by prod profile) ---
PROD_DB_USERNAME=postgres.your-prod-project-ref
PROD_DB_PASSWORD=your_prod_password_here

# --- Development DB (used by dev profile) ---
DEV_DB_USERNAME=postgres.your-dev-project-ref
DEV_DB_PASSWORD=your_dev_password_here

# API keys
GROQ_API_KEY=your_groq_api_key_here
OPENAI_API_KEY=your_openai_api_key_here

# Frontend URLs
FRONTEND_URL=http://localhost:3000
DEV_FRONTEND_URL=http://localhost:3000

# App secrets
VAULT_JWT_SECRET=please-change-this-secret-to-a-long-random-value
